<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Backoffice{% endblock %} — Épicerie Admin</title>
  <link rel="stylesheet" href="{{ asset('css/admin/admin.css') }}">
</head>
<body>
  <div class="admin-shell">
    {% if is_granted('ROLE_ADMIN') %}
  
    <aside class="sidebar">
      {% include 'admin/_sidebar.html.twig' %}
    </aside>
 {% endif %}
    <div class="main">
     {% if is_granted('ROLE_ADMIN') %}
      <header class="topbar">
        {% include 'admin/_topbar.html.twig' %}
      </header>
 {% endif %}
      <main class="page">

        {# ── Flash messages ─────────────────── #}
        {% for type, messages in app.flashes %}
          {% for msg in messages %}
            <div class="flash flash-{{ type }}">
              <div class="flash-icon">
                {% if type == 'success' %}
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {% elseif type == 'warning' %}
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                {% else %}
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                {% endif %}
              </div>
              <div class="flash-msg">{{ msg }}</div>
              <button class="flash-close" onclick="this.closest('.flash').remove()">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>
          {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
      </main>
    </div>
  </div>

  <style>
    /* ── Flash messages ────────────────────── */
    .flash {
      display: flex; align-items: center; gap: 10px;
      padding: 11px 14px; border-radius: 10px;
      margin-bottom: 14px; font-size: 13px; font-weight: 500;
      border: 1.5px solid transparent;
      animation: flashIn .25s ease;
    }
    @keyframes flashIn { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:none; } }
    .flash-success { background: rgba(16,185,129,.08); border-color: rgba(16,185,129,.25); color: #065f46; }
    .flash-warning { background: rgba(245,158,11,.08); border-color: rgba(245,158,11,.28); color: #92400e; }
    .flash-danger  { background: rgba(239,68,68,.08);  border-color: rgba(239,68,68,.25);  color: #991b1b; }
    .flash-icon { flex-shrink: 0; }
    .flash-msg  { flex: 1; }
    .flash-close {
      background: none; border: none; cursor: pointer; padding: 2px;
      opacity: .5; transition: opacity .15s; color: inherit;
    }
    .flash-close:hover { opacity: 1; }
  </style>

  <script>
    // Data-confirm
    document.querySelectorAll('[data-confirm]').forEach(el => {
      el.addEventListener('click', (e) => {
        if (!confirm(el.getAttribute('data-confirm'))) e.preventDefault();
      });
    });

    // Auto-dismiss flash after 5s
    document.querySelectorAll('.flash').forEach(el => {
      setTimeout(() => {
        el.style.transition = 'opacity .4s, transform .4s';
        el.style.opacity = '0';
        el.style.transform = 'translateY(-4px)';
        setTimeout(() => el.remove(), 400);
      }, 5000);
    });
  </script>
</body>
</html>
