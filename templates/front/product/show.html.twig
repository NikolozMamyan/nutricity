{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} – NUTRI CITY{% endblock %}
{% block meta_desc %}{{ product.shortDescription is defined and product.shortDescription ? product.shortDescription : product.name ~ ' disponible en Click & Collect chez NUTRI CITY.' }}{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap');

  /* ─── TOKENS ─────────────────────────────── */
  :root {
    --pg-cream:    #FEFAE0;
    --pg-green:    #2D6A4F;
    --pg-green-l:  #52B788;
    --pg-green-p:  #D8F3DC;
    --pg-dark:     #1B4332;
    --pg-tan:      #DDA15E;
    --pg-brown:    #BC6C25;
    --pg-muted:    #6b7280;
    --pg-border:   rgba(0,0,0,.07);
    --pg-shadow:   0 4px 28px rgba(0,0,0,.07);
    --pg-shadow-l: 0 12px 48px rgba(0,0,0,.12);

    --wrap: 1120px;
    --gutter: clamp(16px, 3vw, 28px);
  }



  /* ─── BASE UTILS ─────────────────────────── */
  .wrap{
    width: min(var(--wrap), calc(100% - (var(--gutter) * 2)));
    margin-inline: auto;
  }

  :where(a, button, input, [role="tab"]):focus-visible{
    outline: 3px solid rgba(82,183,136,.45);
    outline-offset: 3px;
    border-radius: 14px;
  }

  @media (prefers-reduced-motion: reduce){
    *{ animation: none !important; transition: none !important; scroll-behavior: auto !important; }
  }

  /* ─── BREADCRUMB HERO ────────────────────── */
  .pshow-hero {
    background:
      radial-gradient(ellipse at 20% 80%, rgba(82,183,136,.18) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(116,198,157,.1) 0%, transparent 45%),
      linear-gradient(145deg, var(--pg-dark) 0%, var(--pg-green) 100%);
    padding: 2rem 0 1.8rem;
    position: relative;
    overflow: hidden;
  }
  .pshow-hero::after {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .breadcrumb { margin: 0; background: none; padding: 0; list-style: none; display:flex; flex-wrap:wrap; gap:8px; }
  .breadcrumb-item { display:flex; align-items:center; gap:8px; }
  .breadcrumb-item, .breadcrumb-item a {
    font-size: .82rem; color: rgba(255,255,255,.55); text-decoration: none; transition: color .2s;
  }
  .breadcrumb-item a:hover { color: var(--pg-green-l); }
  .breadcrumb-item.active  { color: var(--pg-green-l); font-weight: 600; }
  .crumb-sep{ color: rgba(255,255,255,.2); }

  /* ─── MAIN LAYOUT ────────────────────────── */
  .pshow-main { background: var(--pg-cream); padding: 3.5rem 0 4rem; }

  .pshow-grid{
    display:grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(18px, 3vw, 44px);
    align-items:start;
  }
  .pshow-left, .pshow-right { min-width: 0; }

  /* ─── IMAGE PANEL ────────────────────────── */
  .img-panel { position: sticky; top: 90px; }

  .img-frame {
    border-radius: 28px;
    overflow: hidden;
    background: white;
    aspect-ratio: 1 / 1;
    display: flex; align-items: center; justify-content: center;
    position: relative;
    border: 1.5px solid rgba(45,106,79,.1);
    box-shadow: var(--pg-shadow-l);
  }
  .img-frame::before{
    content:"";
    position:absolute; inset:0;
    border-radius: 28px;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.55);
    pointer-events:none;
  }
  .img-frame img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .5s cubic-bezier(.25,.46,.45,.94);
  }
  .img-frame:hover img { transform: scale(1.04); }

  .img-placeholder {
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    color: var(--pg-green); opacity: .18;
  }
  .img-placeholder svg { width: 72px; height: 72px; }
  .img-placeholder span { font-size: .75rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; }

  .img-badge-new {
    position: absolute; top: 18px; left: 18px;
    background: var(--pg-tan); color: white;
    border-radius: 30px; padding: 6px 16px;
    font-size: .72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 1.5px;
    box-shadow: 0 4px 14px rgba(188,108,37,.3);
  }
  .img-badge-out {
    position: absolute; inset: 0;
    background: rgba(255,255,255,.75);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    border-radius: 28px;
  }
  .img-badge-out span {
    background: #ef4444; color: white;
    border-radius: 30px; padding: 8px 20px;
    font-size: .8rem; font-weight: 700;
    letter-spacing: .04em;
  }

  .img-deco {
    position: absolute; bottom: -20px; right: -20px;
    width: 120px; height: 120px; border-radius: 50%;
    background: radial-gradient(circle, rgba(82,183,136,.12), transparent 70%);
    pointer-events: none;
  }

  .img-dots { display:flex; justify-content:center; gap:6px; margin-top:14px; }
  .img-dot { width:7px; height:7px; border-radius:50%; background: rgba(45,106,79,.25); transition: all .2s; }
  .img-dot.active{ background: var(--pg-green); width: 20px; border-radius:4px; }

  /* ─── INFO PANEL ─────────────────────────── */
  .info-panel { padding-left: .5rem; }

  .cat-tag {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--pg-green-p); color: var(--pg-green);
    border: 1.5px solid rgba(45,106,79,.15);
    border-radius: 30px; padding: 5px 14px;
    font-size: .75rem; font-weight: 700;
    text-decoration: none; margin-bottom: 1rem;
    text-transform: uppercase; letter-spacing: .06em;
    transition: all .2s;
  }
  .cat-tag:hover { background: var(--pg-green); color: white; }

  .product-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    font-weight: 900; color: var(--pg-dark);
    line-height: 1.1; margin-bottom: .9rem;
    letter-spacing: -.01em;
  }

  .product-short-desc {
    font-size: .95rem; color: var(--pg-muted);
    line-height: 1.75; margin-bottom: 1.5rem;
    font-weight: 400;
    max-width: 68ch;
  }

  .price-row { display:flex; align-items: baseline; gap:10px; margin-bottom: 1.2rem; }
  .price-val {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem; font-weight: 900;
    color: var(--pg-green); line-height: 1;
    letter-spacing: -.02em;
  }
  .price-unit { font-size: .82rem; color: var(--pg-muted); font-weight: 500; }

  .stock-pill {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .82rem; font-weight: 600;
    padding: 6px 14px; border-radius: 30px;
    margin-bottom: 1.3rem; border: 1.5px solid transparent;
  }
  .stock-pill.in  { background: rgba(45,106,79,.08); border-color: rgba(45,106,79,.2); color: var(--pg-green); }
  .stock-pill.low { background: rgba(245,158,11,.08); border-color: rgba(245,158,11,.25); color: #d97706; }
  .stock-pill.out { background: rgba(239,68,68,.07); border-color: rgba(239,68,68,.2); color: #dc2626; }
  .sdot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .stock-pill.in  .sdot { background: var(--pg-green); box-shadow: 0 0 0 3px rgba(45,106,79,.2); animation: pulse 2s infinite; }
  .stock-pill.low .sdot { background: #d97706; }
  .stock-pill.out .sdot { background: #dc2626; }
  @keyframes pulse { 0%,100%{box-shadow:0 0 0 3px rgba(45,106,79,.2);} 50%{box-shadow:0 0 0 5px rgba(45,106,79,.1);} }

  .trust-strip { display:flex; gap:8px; flex-wrap:wrap; margin-bottom: 1.4rem; }
  .trust-pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: white; border: 1.5px solid var(--pg-border);
    border-radius: 10px; padding: 6px 12px;
    font-size: .76rem; font-weight: 500; color: var(--pg-muted);
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
  }
  .trust-pill svg { color: var(--pg-green); width: 13px; height: 13px; }

  .info-div { border: none; border-top: 1px solid rgba(0,0,0,.07); margin: 1.4rem 0; }

  /* ─── TABS ───────────────────────────────── */
  .tabs-nav{
    display:flex;
    gap:0;
    border-bottom: 2px solid rgba(0,0,0,.07);
    margin-bottom: 1.3rem;

    overflow-x:auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width:none;
  }
  .tabs-nav::-webkit-scrollbar{ display:none; }

  .tab-btn{
    padding: .6rem 1.2rem;
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem; font-weight: 600;
    color: var(--pg-muted); cursor:pointer;
    border: none; background:none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px; transition: color .2s, border-color .2s;
    display:flex; align-items:center; gap:6px;
    white-space: nowrap;
  }
  .tab-btn svg { width: 13px; height: 13px; }
  .tab-btn:hover { color: var(--pg-green); }
  .tab-btn.active { color: var(--pg-green); border-bottom-color: var(--pg-green); }

  .tab-panel { display:none; animation: fadeUp .2s ease; }
  .tab-panel.active{ display:block; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(5px);} to{opacity:1;transform:none;} }

  .product-desc { font-size: .92rem; line-height: 1.8; color: var(--pg-muted); max-width: 68ch; }
  .product-desc p{ margin: .65rem 0; }
  .product-desc ul, .product-desc ol{ padding-left: 1.15rem; }

  .feat-list { list-style: none; padding: 0; margin: 0; }
  .feat-list li {
    display:flex; align-items:flex-start; gap:12px;
    font-size: .88rem; color: var(--pg-muted);
    padding: .7rem 0; border-bottom: 1px solid rgba(0,0,0,.05);
  }
  .feat-list li:last-child { border-bottom:none; }
  .feat-list svg { color: var(--pg-green); flex-shrink:0; width:14px; height:14px; margin-top:2px; }
  .feat-list strong { color: var(--pg-dark); display:block; font-size: .82rem; margin-bottom: 1px; }

  /* ─── CTA BOX ────────────────────────────── */
  .cta-box{
    background:white;
    border: 1.5px solid rgba(45,106,79,.12);
    border-radius: 22px;
    padding: 1.8rem;
    margin-top: 1.5rem;
    box-shadow: var(--pg-shadow);
    position:relative; overflow:hidden;
  }
  .cta-box::before{
    content:'';
    position:absolute; top:0; left:0; right:0; height:3px;
    background: linear-gradient(90deg, var(--pg-green), var(--pg-green-l));
  }
  .cta-box-title{
    font-size: 1rem; font-weight:700; color: var(--pg-dark);
    margin-bottom: .25rem;
    display:flex; align-items:center; gap:8px;
  }
  .cta-box-title svg{ color: var(--pg-green); width:17px; height:17px; }
  .cta-box-sub{ font-size:.8rem; color: var(--pg-muted); margin-bottom: 1.3rem; line-height: 1.6; }

  .qty-row{ display:flex; align-items:center; gap:14px; margin-bottom: 1.2rem; flex-wrap: wrap; }
  .qty-label{ font-size: .82rem; font-weight:600; color: var(--pg-dark); }
  .qty-ctrl{
    display:flex; align-items:center;
    background: var(--pg-cream);
    border: 1.5px solid rgba(0,0,0,.1);
    border-radius: 12px;
    overflow:hidden;
  }
  .qty-btn{
    width:38px; height:38px; border:none; background:none;
    color: var(--pg-green); cursor:pointer;
    display:flex; align-items:center; justify-content:center;
    transition: background .15s;
  }
  .qty-btn:hover{ background: var(--pg-green-p); }
  .qty-btn svg{ width:13px; height:13px; }
  .qty-num{
    width:44px; text-align:center; border:none; background:none;
    font-size: .95rem; font-weight:700; color: var(--pg-dark);
    border-left: 1.5px solid rgba(0,0,0,.08);
    border-right: 1.5px solid rgba(0,0,0,.08);
    padding:0; height:38px;
  }
  .qty-num:focus{ outline:none; }

  .btn-cart{
    display:flex; align-items:center; justify-content:center; gap:10px;
    width:100%;
    background: linear-gradient(135deg, var(--pg-green) 0%, var(--pg-green-l) 100%);
    color:white; border:none; border-radius: 14px;
    padding: 1rem 1.5rem;
    font-size: .95rem; font-weight:700;
    cursor:pointer;
    box-shadow: 0 6px 22px rgba(45,106,79,.28);
    transition: transform .2s, box-shadow .2s, opacity .2s;
  }
  .btn-cart:hover{ transform: translateY(-2px); box-shadow: 0 10px 32px rgba(45,106,79,.38); color:white; }
  .btn-cart:active{ transform: translateY(0); }
  .btn-cart:disabled{ opacity:.5; cursor:not-allowed; transform:none; }
  .btn-cart svg{ width:18px; height:18px; }

  .btn-back{
    display:flex; align-items:center; justify-content:center; gap:8px;
    width:100%; margin-top: .7rem;
    background: transparent; color: var(--pg-muted);
    border: 1.5px solid rgba(0,0,0,.1); border-radius: 14px;
    padding: .85rem;
    font-size: .88rem; font-weight:600; cursor:pointer;
    text-decoration:none;
    transition: all .2s;
  }
  .btn-back:hover{ border-color: var(--pg-green); color: var(--pg-green); }
  .btn-back svg{ width:14px; height:14px; }

  .cta-out{ text-align:center; padding: 1.5rem 0 .5rem; }
  .cta-out-title{ font-size:1rem; font-weight:700; color:#dc2626; margin-bottom:.4rem; display:flex; align-items:center; justify-content:center; gap:8px; }
  .cta-out-title svg{ width:18px; height:18px; }
  .cta-out-sub{ font-size:.82rem; color: var(--pg-muted); margin-bottom: 1rem; }

  /* ─── RELATED SECTION ────────────────────── */
  .related-section{
    background:white;
    border-top: 1px solid rgba(0,0,0,.06);
    padding: 4.5rem 0 5rem;
  }
  .section-eyebrow{
    font-size: .7rem; font-weight:700; letter-spacing: .14em;
    text-transform: uppercase; color: var(--pg-green-l);
    margin-bottom: .4rem; display:flex; align-items:center; gap:7px;
  }
  .section-eyebrow::before{
    content:'';
    display:block; width:24px; height:2px;
    background: var(--pg-green-l); border-radius:2px;
  }
  .section-heading{
    font-family:'Playfair Display', serif;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight:900; color: var(--pg-dark); line-height:1.2;
  }

  .rel-grid{
    display:grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .rel-card{
    border-radius: 18px; overflow:hidden;
    background: var(--pg-cream);
    border: 1.5px solid rgba(0,0,0,.06);
    text-decoration:none; color: inherit;
    display:flex; flex-direction:column;
    transition: transform .28s cubic-bezier(.25,.46,.45,.94), box-shadow .28s;
    min-height: 100%;
  }
  .rel-card:hover{ transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,.1); color: inherit; }
  .rel-card-img{
    aspect-ratio: 4/3; background: var(--pg-green-p);
    overflow:hidden; display:flex; align-items:center; justify-content:center;
  }
  .rel-card-img img{ width:100%; height:100%; object-fit:cover; transition: transform .4s ease; }
  .rel-card:hover .rel-card-img img{ transform: scale(1.08); }
  .rel-card-img svg{ width:40px; height:40px; color: var(--pg-green); opacity:.25; }
  .rel-card-body{ padding: 1rem 1.1rem; flex: 1; display:flex; flex-direction:column; }
  .rel-card-cat{ font-size: .68rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color: var(--pg-green-l); margin-bottom:.25rem; }
  .rel-card-name{ font-size: .95rem; font-weight:700; color: var(--pg-dark); margin-bottom:.4rem; line-height: 1.3; }
  .rel-card-price{ font-size: 1rem; font-weight:800; color: var(--pg-green); margin-top:auto; font-family: 'DM Mono', monospace; }

  /* ─── TOAST ──────────────────────────────── */
  .toast-container{
    position: fixed; bottom: 28px; right: 20px;
    z-index: 9999;
    display:flex; flex-direction:column; gap:10px;
    pointer-events:none;
  }
  .toast-notif{
    background:white; border-radius:18px;
    box-shadow: 0 8px 40px rgba(0,0,0,.14);
    min-width: 280px; max-width: 360px; overflow:hidden;
    transform: translateX(120%);
    transition: transform .38s cubic-bezier(.34,1.56,.64,1);
    pointer-events: all;
  }
  .toast-notif.show{ transform: translateX(0); }
  .toast-notif.hide{ transform: translateX(120%); transition: transform .28s ease; }
  .toast-inner{ display:flex; align-items:flex-start; gap:12px; padding: 14px 15px; }
  .toast-icon{
    width:38px; height:38px; border-radius:11px;
    background: var(--pg-green-p);
    display:flex; align-items:center; justify-content:center;
    flex-shrink:0;
  }
  .toast-icon svg{ width:17px; height:17px; color: var(--pg-green); }
  .toast-icon.warning{ background: rgba(245,158,11,.12); }
  .toast-icon.warning svg{ color:#d97706; }
  .toast-icon.error{ background: rgba(239,68,68,.1); }
  .toast-icon.error svg{ color:#dc2626; }
  .toast-text{ flex:1; }
  .toast-title{ font-size:.86rem; font-weight:700; color: var(--pg-dark); margin-bottom:2px; }
  .toast-msg{ font-size:.78rem; color: var(--pg-muted); line-height:1.4; }
  .toast-close{ background:none; border:none; color: var(--pg-muted); cursor:pointer; padding:2px; opacity:.5; align-self:flex-start; }
  .toast-close:hover{ opacity:1; }
  .toast-progress{ height:3px; background: var(--pg-green); width:100%; transform-origin:left; animation: tprog 3.5s linear forwards; }
  .toast-progress.error{ background:#dc2626; }
  @keyframes tprog{ from{transform:scaleX(1);} to{transform:scaleX(0);} }

  /* Stagger reveal */
  .reveal { opacity: 0; transform: translateY(18px); transition: opacity .5s ease, transform .5s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  /* ─── RESPONSIVE ─────────────────────────── */
  @media (max-width: 980px){
    .pshow-grid{ grid-template-columns: 1fr; }
    .info-panel{ padding-left: 0; margin-top: 2rem; }
    .img-panel{ position: static; }
    .rel-grid{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 520px){
    .price-val{ font-size: 1.9rem; }
    .cta-box{ padding: 1.4rem; }
    .rel-grid{ grid-template-columns: 1fr; }
  }
</style>

{# ── Toast container (vanilla) ──────────── #}
<div class="toast-container" aria-live="polite" data-toast-container></div>

{# ── HERO / BREADCRUMB ────────────────────── #}
<div class="pshow-hero">
  <div class="wrap">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item">
          <a href="{{ path('home') }}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:3px;"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Accueil
          </a>
        </li>
        <span class="crumb-sep">/</span>
        <li class="breadcrumb-item"><a href="{{ path('catalogue') }}">Nos produits</a></li>

        {% if product.category is defined %}
          <span class="crumb-sep">/</span>
          <li class="breadcrumb-item">
            <a href="{{ path('catalogue', {category: product.category.id}) }}">{{ product.category.name }}</a>
          </li>
        {% endif %}

        <span class="crumb-sep">/</span>
        <li class="breadcrumb-item active" aria-current="page">
          {{ product.name|length > 38 ? product.name|slice(0,38) ~ '…' : product.name }}
        </li>
      </ol>
    </nav>
  </div>
</div>

{# ── MAIN PRODUCT SECTION ─────────────────── #}
<section class="pshow-main"
  data-controller="product-show"
  data-product-show-cart-data-url-value="{{ path('cart_data')|default('/panier/donnees') }}"
  data-product-show-add-url-value="{{ path('cart_add', {id: product.id})|default('/panier/ajouter/' ~ product.id) }}"
  data-product-show-product-id-value="{{ product.id }}"
  data-product-show-product-name-value="{{ product.name|e('html_attr') }}"
  data-product-show-max-qty-value="{{ product.stock is defined ? product.stock : 99 }}"
  data-product-show-cart-url-value="{{ path('click_collect')|default('/click-collect') }}"
>
  <div class="wrap">
    <div class="pshow-grid">

      {# ── LEFT: Image ─────────────────────── #}
      <div class="pshow-left">
        <div class="img-panel">
          <div class="img-frame">
            {% if product.image is defined and product.image %}
              <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" loading="eager">
            {% else %}
              <div class="img-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
                  <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
                <span>Image à venir</span>
              </div>
            {% endif %}

            {% if product.isNew is defined and product.isNew %}
              <span class="img-badge-new">Nouveau</span>
            {% endif %}

            {% if product.stock is defined and product.stock == 0 %}
              <div class="img-badge-out"><span>Rupture de stock</span></div>
            {% endif %}

            <div class="img-deco"></div>
          </div>

          <div class="img-dots" aria-hidden="true">
            <div class="img-dot active"></div>
          </div>
        </div>
      </div>

      {# ── RIGHT: Info ─────────────────────── #}
      <div class="pshow-right">
        <div class="info-panel">

          {% if product.category is defined %}
            <a href="{{ path('catalogue', {category: product.category.id}) }}" class="cat-tag">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              {{ product.category.name }}
            </a>
          {% endif %}

          <h1 class="product-title">{{ product.name }}</h1>

          {% if product.shortDescription is defined and product.shortDescription %}
            <p class="product-short-desc">{{ product.shortDescription }}</p>
          {% endif %}

          {% if product.price is defined %}
            <div class="price-row">
              <span class="price-val">{{ product.price|number_format(2, ',', ' ') }} €</span>
              {% if product.unit is defined and product.unit %}
                <span class="price-unit">/ {{ product.unit }}</span>
              {% endif %}
            </div>
          {% endif %}

          {% if product.stock is defined %}
            {% if product.stock > 10 %}
              <div class="stock-pill in">
                <span class="sdot"></span> En stock — {{ product.stock }} disponibles
              </div>
            {% elseif product.stock > 0 %}
              <div class="stock-pill low">
                <span class="sdot"></span> Plus que {{ product.stock }} en stock !
              </div>
            {% else %}
              <div class="stock-pill out">
                <span class="sdot"></span> Rupture de stock
              </div>
            {% endif %}
          {% endif %}

          <div class="trust-strip" aria-label="Garanties et infos">
            <span class="trust-pill">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              Retrait en magasin
            </span>
            <span class="trust-pill">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Prêt sous 2h
            </span>
            <span class="trust-pill">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Sélection Europe de l'Est
            </span>
          </div>

          <hr class="info-div">

          {# ── Tabs ──────────────────────────── #}
          <div class="tabs-nav" role="tablist" aria-label="Informations produit">
            <button type="button" class="tab-btn active"
              role="tab" aria-selected="true" aria-controls="tab-desc"
              data-tab-btn="tab-desc">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="21" y1="6" x2="3" y2="6"/><line x1="15" y1="12" x2="3" y2="12"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
              Description
            </button>

            <button type="button" class="tab-btn"
              role="tab" aria-selected="false" aria-controls="tab-info"
              data-tab-btn="tab-info">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Informations
            </button>
          </div>

          <div id="tab-desc" class="tab-panel active" role="tabpanel">
            {% if product.longDescription is defined and product.longDescription %}
              <div class="product-desc">{{ product.longDescription|nl2br }}</div>
            {% elseif product.description is defined and product.description %}
              <div class="product-desc">{{ product.description|nl2br }}</div>
            {% else %}
              <p class="product-desc" style="font-style:italic;">Aucune description disponible.</p>
            {% endif %}
          </div>

          <div id="tab-info" class="tab-panel" role="tabpanel">
            <ul class="feat-list">
              {% if product.category is defined %}
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                  <div><strong>Catégorie</strong>{{ product.category.name }}</div>
                </li>
              {% endif %}
              {% if product.origin is defined and product.origin %}
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
                  <div><strong>Origine</strong>{{ product.origin }}</div>
                </li>
              {% endif %}
              {% if product.unit is defined and product.unit %}
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                  <div><strong>Conditionnement</strong>{{ product.unit }}</div>
                </li>
              {% endif %}
              {% if product.stock is defined %}
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8"/></svg>
                  <div><strong>Stock</strong>{{ product.stock }} unité(s) disponible(s)</div>
                </li>
              {% endif %}
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <div><strong>Mode de retrait</strong>Click &amp; Collect — Strasbourg</div>
              </li>
            </ul>
          </div>

          {# ── CTA Box ─────────────────────────── #}
          {% if product.stock is not defined or product.stock > 0 %}
            <div class="cta-box"
              data-product-id="{{ product.id }}"
              data-add-url="{{ path('cart_add', {id: product.id})|default('/panier/ajouter/' ~ product.id) }}"
              data-cart-url="{{ path('click_collect')|default('/click-collect') }}"
              data-product-name="{{ product.name|e('html_attr') }}"
              data-max-qty="{{ product.stock is defined ? product.stock : 99 }}"
            >
              <div class="cta-box-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.96-1.61L23 6H6"/></svg>
                Ajouter à mon panier
              </div>
              <div class="cta-box-sub">Sans inscription. Récupérez votre commande directement en magasin.</div>

              <div class="qty-row">
                <span class="qty-label">Quantité :</span>
                <div class="qty-ctrl">
                  <button class="qty-btn" type="button" aria-label="Diminuer" data-qty-minus>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                  <input class="qty-num" type="number" min="1"
                    max="{{ product.stock is defined ? product.stock : 99 }}"
                    value="1" aria-label="Quantité"
                    data-qty-input>
                  <button class="qty-btn" type="button" aria-label="Augmenter" data-qty-plus>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                </div>
              </div>

              <button class="btn-cart" type="button" data-add-to-cart>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.96-1.61L23 6H6"/></svg>
                Ajouter au panier
              </button>

              <a href="{{ path('catalogue') }}" class="btn-back">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                Continuer mes achats
              </a>
            </div>
          {% else %}
            <div class="cta-box">
              <div class="cta-out">
                <div class="cta-out-title">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                  Produit indisponible
                </div>
                <div class="cta-out-sub">Ce produit est actuellement en rupture de stock. Revenez bientôt !</div>
                <a href="{{ path('catalogue') }}" class="btn-back" style="max-width:280px;margin:0 auto;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                  Voir les autres produits
                </a>
              </div>
            </div>
          {% endif %}

        </div>
      </div>

    </div>
  </div>
</section>

{# ── RELATED PRODUCTS ─────────────────────── #}
{% if related is not empty %}
<section class="related-section">
  <div class="wrap">

    <div class="rel-head">
      <div>
        <div class="section-eyebrow">Dans la même catégorie</div>
        <h2 class="section-heading">Vous aimerez aussi</h2>
      </div>

      {% if product.category is defined %}
        <a href="{{ path('catalogue', {category: product.category.id}) }}"
           style="display:inline-flex;align-items:center;gap:7px;font-size:.85rem;font-weight:700;color:var(--pg-green);text-decoration:none;">
          Voir tout
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {% endif %}
    </div>

    <div class="rel-grid">
      {% for rel in related %}
        <a href="{{ path('product_show', {slug: rel.slug}) }}" class="rel-card reveal" style="transition-delay:{{ loop.index0 * 0.08 }}s;">
          <div class="rel-card-img">
            {% if rel.image is defined and rel.image %}
              <img src="{{ asset('uploads/products/' ~ rel.image) }}" alt="{{ rel.name }}" loading="lazy">
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            {% endif %}
          </div>
          <div class="rel-card-body">
            {% if rel.category is defined %}
              <div class="rel-card-cat">{{ rel.category.name }}</div>
            {% endif %}
            <div class="rel-card-name">{{ rel.name }}</div>
            {% if rel.price is defined %}
              <div class="rel-card-price">{{ rel.price|number_format(2, ',', ' ') }} €</div>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>

  </div>
</section>
{% endif %}

<script>
(() => {
  const $ = (sel, root=document) => root.querySelector(sel);
  const $$ = (sel, root=document) => Array.from(root.querySelectorAll(sel));

  /* ── Tabs (vanilla, a11y) ───────────────── */
  const tabButtons = $$('[data-tab-btn]');
  const tabPanels  = $$('.tab-panel');

  function activateTab(id) {
    tabButtons.forEach(btn => {
      const isActive = btn.getAttribute('data-tab-btn') === id;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    tabPanels.forEach(p => p.classList.toggle('active', p.id === id));
  }

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => activateTab(btn.getAttribute('data-tab-btn')));
  });

  /* ── Qty controls ───────────────────────── */
  const cta = $('.cta-box[data-add-url]');
  if (cta) {
    const input = $('[data-qty-input]', cta);
    const minus = $('[data-qty-minus]', cta);
    const plus  = $('[data-qty-plus]', cta);
    const btnAdd = $('[data-add-to-cart]', cta);

    const max = Number(cta.getAttribute('data-max-qty') || input.max || 99);

    const clamp = (v) => Math.max(1, Math.min(max, v));

    const sync = () => {
      const v = clamp(Number(input.value || 1));
      input.value = v;
      if (btnAdd) btnAdd.disabled = (max <= 0);
      minus.disabled = (v <= 1);
      plus.disabled  = (v >= max);
    };

    minus?.addEventListener('click', () => { input.value = clamp(Number(input.value || 1) - 1); sync(); });
    plus?.addEventListener('click',  () => { input.value = clamp(Number(input.value || 1) + 1); sync(); });
    input?.addEventListener('input', sync);
    input?.addEventListener('change', sync);
    sync();

    /* ── Toast helper ─────────────────────── */
    const toastRoot = $('[data-toast-container]');
    function toast({title, msg, type='success'}) {
      if (!toastRoot) return;
      const icons = {
        success: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>',
        warning: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
        error:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
      };

      const el = document.createElement('div');
      el.className = 'toast-notif';
      el.innerHTML = `
        <div class="toast-inner">
          <div class="toast-icon ${type === 'warning' ? 'warning' : type === 'error' ? 'error' : ''}">${icons[type] || icons.success}</div>
          <div class="toast-text">
            <div class="toast-title">${title || 'Info'}</div>
            <div class="toast-msg">${msg || ''}</div>
          </div>
          <button class="toast-close" aria-label="Fermer">✕</button>
        </div>
        <div class="toast-progress ${type === 'error' ? 'error' : ''}"></div>
      `;
      toastRoot.appendChild(el);

      const close = () => {
        el.classList.add('hide');
        setTimeout(() => el.remove(), 250);
      };
      el.querySelector('.toast-close')?.addEventListener('click', close);

      requestAnimationFrame(() => el.classList.add('show'));
      setTimeout(close, 3500);
    }

    /* ── Add to cart (fetch) ──────────────── */
    btnAdd?.addEventListener('click', async () => {
      const url = cta.getAttribute('data-add-url');
      const qty = Number(input.value || 1);

      btnAdd.disabled = true;
      const old = btnAdd.innerHTML;
      btnAdd.style.opacity = '0.85';
      btnAdd.innerHTML = old.replace('Ajouter au panier', 'Ajout...');

      try {
        // Si ton endpoint accepte POST JSON :
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ quantity: qty })
        });

        // Si ton endpoint attend du form-urlencoded, remplace par :
        // const res = await fetch(url, { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded','X-Requested-With':'XMLHttpRequest'}, body: new URLSearchParams({ quantity: qty }) });

        if (!res.ok) throw new Error('Erreur serveur');
        toast({ title: 'Ajouté au panier', msg: `${cta.getAttribute('data-product-name')} (x${qty})`, type: 'success' });
        btnAdd.innerHTML = old.replace('Ajouter au panier', 'Ajouté ✓');
        setTimeout(() => { btnAdd.innerHTML = old; }, 1200);
      } catch (e) {
        toast({ title: 'Oups', msg: "Impossible d'ajouter au panier. Réessaie.", type: 'error' });
        btnAdd.innerHTML = old;
      } finally {
        btnAdd.disabled = false;
        btnAdd.style.opacity = '';
        sync();
      }
    });
  }

  /* ── Scroll reveal for related cards ─────── */
  const items = $$('.reveal');
  if (items.length) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    items.forEach(el => obs.observe(el));
  }
})();
</script>
{% endblock %}