{% extends 'admin/layout.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block body %}
<style>
  .product-form-shell {
    max-width: 1120px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .product-form-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) 340px;
    gap: 18px;
  }

  .panel-stack {
    display: grid;
    gap: 14px;
  }

  .fcard {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid var(--border);
    border-radius: 22px;
    box-shadow: var(--shadow-sm);
    padding: 20px;
  }

  .fcard-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }

  .fcard-title {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    font-weight: 800;
    color: var(--nutri-dark);
  }

  .fcard-title-icon {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(82, 183, 136, 0.12);
    color: var(--nutri-green);
  }

  .fgrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .fgrid .full {
    grid-column: 1 / -1;
  }

  .product-form-shell label {
    display: block;
    margin-bottom: 6px;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .product-form-shell .form-help-text,
  .product-form-shell .help-text {
    display: block;
    margin-top: 5px;
    color: var(--text-muted);
    font-size: 0.74rem;
  }

  .product-form-shell .form-error-message,
  .product-form-shell .invalid-feedback,
  .product-form-shell ul {
    margin: 6px 0 0;
    padding: 0;
    list-style: none;
    color: #b91c1c;
    font-size: 0.74rem;
  }

  .toggle-grid {
    display: grid;
    gap: 10px;
  }

  .toggle-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: #fff;
  }

  .toggle-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    accent-color: var(--nutri-green);
  }

  .toggle-title {
    color: var(--nutri-dark);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .toggle-sub {
    margin-top: 3px;
    color: var(--text-muted);
    font-size: 0.76rem;
  }

  .media-preview {
    aspect-ratio: 1;
    border-radius: 20px;
    overflow: hidden;
    background:
      radial-gradient(circle at top, rgba(116, 198, 157, 0.22), transparent 52%),
      linear-gradient(180deg, rgba(216, 243, 220, 0.72), #fff);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }

  .media-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-placeholder {
    display: grid;
    justify-items: center;
    gap: 10px;
    color: var(--text-muted);
    text-align: center;
    padding: 20px;
  }

  .media-placeholder-icon {
    width: 56px;
    height: 56px;
    border-radius: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(82, 183, 136, 0.14);
    color: var(--nutri-green);
    font-size: 1.2rem;
  }

  .stat-list {
    display: grid;
    gap: 10px;
  }

  .stat-row {
    min-height: 46px;
    padding: 0 14px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    font-size: 0.84rem;
  }

  .stat-row strong {
    color: var(--nutri-dark);
  }

  .submit-bar {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .btn-save {
    min-height: 46px;
    padding: 0 18px;
    border-radius: 14px;
    border: none;
    background: linear-gradient(135deg, var(--nutri-green), var(--nutri-green-light));
    color: #fff;
    font-size: 0.9rem;
    font-weight: 800;
    cursor: pointer;
  }

  @media (max-width: 980px) {
    .product-form-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .fgrid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="product-form-shell">
  {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

  <a href="{{ path('admin_products_index') }}" class="back-link">
    <span>&larr;</span>
    Retour aux produits
  </a>

  <div class="page-intro">
    <div>
      <h1 class="page-title">{{ title }}</h1>
      <div class="page-subtitle">Catalogue, visibilite, image et contenu produit.</div>
    </div>
    <div class="page-actions">
      <a class="btn" href="{{ path('admin_products_index') }}">Annuler</a>
      <button type="submit" class="btn-save">Enregistrer</button>
    </div>
  </div>

  <div class="product-form-grid">
    <div class="panel-stack">
      <section class="fcard">
        <div class="fcard-head">
          <div class="fcard-title">
            <span class="fcard-title-icon">P</span>
            Informations produit
          </div>
        </div>
        <div class="fgrid">
          <div>{{ form_row(form.name) }}</div>
          <div>{{ form_row(form.slug) }}</div>
          <div>{{ form_row(form.category) }}</div>
          <div>{{ form_row(form.origin) }}</div>
        </div>
      </section>

      <section class="fcard">
        <div class="fcard-head">
          <div class="fcard-title">
            <span class="fcard-title-icon">E</span>
            Vente
          </div>
        </div>
        <div class="fgrid">
          <div>{{ form_row(form.price) }}</div>
          <div>{{ form_row(form.stock) }}</div>
        </div>
      </section>

      <section class="fcard">
        <div class="fcard-head">
          <div class="fcard-title">
            <span class="fcard-title-icon">T</span>
            Textes
          </div>
        </div>
        <div class="fgrid">
          <div class="full">{{ form_row(form.shortDescription) }}</div>
          <div class="full">{{ form_row(form.longDescription) }}</div>
        </div>
      </section>

      <section class="fcard">
        <div class="fcard-head">
          <div class="fcard-title">
            <span class="fcard-title-icon">S</span>
            SEO
          </div>
        </div>
        <div class="fgrid">
          <div class="full">{{ form_row(form.metaTitle) }}</div>
          <div class="full">{{ form_row(form.metaDescription) }}</div>
        </div>
      </section>
    </div>

    <div class="panel-stack">
      <section class="fcard">
        <div class="fcard-head">
          <div class="fcard-title">
            <span class="fcard-title-icon">I</span>
            Image
          </div>
        </div>

        <div class="media-preview">
          {% if product.photo %}
            {% set currentPhoto = product.photo|split('/')|last %}
            <img src="{{ asset('uploads/products/' ~ currentPhoto) }}" alt="{{ product.name }}">
          {% else %}
            <div class="media-placeholder">
              <div class="media-placeholder-icon">IMG</div>
              <div>
                <strong>Aucune image</strong><br>
                Ajoute un visuel produit.
              </div>
            </div>
          {% endif %}
        </div>

        {{ form_row(form.imageFile) }}

        {% if product.photo %}
          <div style="margin-top:12px;">
            {{ form_row(form.removePhoto) }}
          </div>
        {% else %}
          <div style="display:none;">
            {{ form_widget(form.removePhoto) }}
          </div>
        {% endif %}
      </section>

      <section class="fcard">
        <div class="fcard-head">
          <div class="fcard-title">
            <span class="fcard-title-icon">V</span>
            Visibilite
          </div>
        </div>

        <div class="toggle-grid">
          <label class="toggle-item">
            {{ form_widget(form.active) }}
            <span>
              <span class="toggle-title">Produit actif</span>
              <span class="toggle-sub">Visible dans la boutique.</span>
            </span>
          </label>

          <label class="toggle-item">
            {{ form_widget(form.isNew) }}
            <span>
              <span class="toggle-title">Badge nouveau</span>
              <span class="toggle-sub">Met le produit en avant sur le front.</span>
            </span>
          </label>
        </div>
      </section>

      <section class="fcard">
        <div class="fcard-head">
          <div class="fcard-title">
            <span class="fcard-title-icon">R</span>
            Resume
          </div>
        </div>

        <div class="stat-list">
          <div class="stat-row">
            <span>Photo actuelle</span>
            <strong>{{ product.photo ? product.photo|split('/')|last : 'Aucune' }}</strong>
          </div>
          <div class="stat-row">
            <span>Etat</span>
            <strong>{{ product.active ? 'En ligne' : 'Masque' }}</strong>
          </div>
          <div class="stat-row">
            <span>Stock</span>
            <strong>{{ product.stock ?: 0 }}</strong>
          </div>
        </div>
      </section>
    </div>
  </div>

  <div class="submit-bar">
    <a class="btn" href="{{ path('admin_products_index') }}">Annuler</a>
    <button type="submit" class="btn-save">Enregistrer le produit</button>
  </div>

  {{ form_end(form) }}
</div>
{% endblock %}
