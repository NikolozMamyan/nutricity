{% extends 'base.html.twig' %}
{% block title %}Contact – {{ store.name }}{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap');
  :root{
    --pg-cream:#FEFAE0; --pg-green:#2D6A4F; --pg-green-l:#52B788; --pg-green-p:#D8F3DC;
    --pg-dark:#1B4332; --pg-muted:#6b7280; --pg-border:rgba(0,0,0,.07);
    --pg-shadow:0 4px 28px rgba(0,0,0,.07); --pg-shadow-l:0 12px 48px rgba(0,0,0,.12);
    --wrap:1120px; --gutter:clamp(16px, 3vw, 28px);
  }
  .wrap{ width:min(var(--wrap), calc(100% - (var(--gutter) * 2))); margin-inline:auto; }
  :where(a,button,input,textarea,select):focus-visible{ outline:3px solid rgba(82,183,136,.45); outline-offset:3px; border-radius:14px; }

  .hero{
    background:
      radial-gradient(ellipse at 20% 80%, rgba(82,183,136,.18) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(116,198,157,.1) 0%, transparent 45%),
      linear-gradient(145deg, var(--pg-dark) 0%, var(--pg-green) 100%);
    padding: 2.6rem 0 2rem;
    position:relative; overflow:hidden;
  }
  .hero::after{ content:''; position:absolute; inset:0;
    background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px; pointer-events:none;
  }
  .h1{
    font-family:'Playfair Display',serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900; color:#fff; line-height:1.05; margin:0 0 .7rem;
  }
  .lead{ color: rgba(255,255,255,.75); line-height:1.7; margin:0; max-width:70ch; }

  .main{ padding: 3rem 0 4.5rem; }
  .grid{ display:grid; grid-template-columns: 1fr 1fr; gap: clamp(16px, 3vw, 36px); align-items:start; }

  .card{
    background:#fff; border:1.5px solid rgba(45,106,79,.12); border-radius:22px;
    box-shadow: var(--pg-shadow); padding: 1.6rem; position:relative; overflow:hidden;
  }
  .card::before{ content:''; position:absolute; top:0; left:0; right:0; height:3px;
    background: linear-gradient(90deg, var(--pg-green), var(--pg-green-l));
  }
  .card h2{ font-weight:900; color:var(--pg-dark); margin:.2rem 0 1rem; font-size:1.25rem; }
  .muted{ color:var(--pg-muted); line-height:1.8; font-size:.92rem; margin:0 0 1.1rem; }

  .meta{
    display:grid; gap:10px; margin-bottom: 1.2rem;
  }
  .meta-item{
    display:flex; gap:10px; align-items:flex-start;
    padding: 10px 12px; border-radius: 16px;
    background: var(--pg-green-p); border: 1.5px solid rgba(45,106,79,.14);
    color: var(--pg-green);
    font-size:.9rem; font-weight:700;
  }
  .meta-item span{ color: var(--pg-green); font-weight:800; }
  .meta-item small{ display:block; color: rgba(27,67,50,.75); font-weight:600; margin-top:2px; }
  .meta-item svg{ width:18px; height:18px; flex-shrink:0; margin-top:2px; }

  .map{
    border-radius: 18px;
    overflow:hidden;
    border: 1.5px solid rgba(0,0,0,.08);
    box-shadow: var(--pg-shadow-l);
    background: #fff;
    aspect-ratio: 16/11;
  }
  .map iframe{ width:100%; height:100%; border:0; }

  .flash{
    border-radius: 16px;
    padding: 12px 14px;
    border: 1.5px solid rgba(34,197,94,.25);
    background: rgba(34,197,94,.08);
    color: #166534;
    font-weight: 700;
    margin-bottom: 14px;
  }

  /* Form */
  .form-row{ display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .field{ margin-bottom: 12px; }
  label{ display:block; font-weight:800; color:var(--pg-dark); font-size:.9rem; margin-bottom:6px; }
  input, textarea{
    width:100%;
    background: var(--pg-cream);
    border: 1.5px solid rgba(0,0,0,.10);
    border-radius: 14px;
    padding: 12px 12px;
    font-size: .95rem;
    color: var(--pg-dark);
    transition: border-color .2s, box-shadow .2s;
  }
  input:focus, textarea:focus{
    outline:none;
    border-color: rgba(82,183,136,.55);
    box-shadow: 0 0 0 4px rgba(82,183,136,.18);
    background:#fff;
  }
  .error{
    color:#dc2626;
    font-size:.85rem;
    margin-top:6px;
    font-weight:700;
  }

  .btn{
    display:flex; align-items:center; justify-content:center; gap:10px;
    width:100%;
    background: linear-gradient(135deg, var(--pg-green) 0%, var(--pg-green-l) 100%);
    color:#fff; border:none; border-radius: 14px;
    padding: 1rem 1.2rem;
    font-size: .95rem; font-weight: 800;
    cursor:pointer;
    box-shadow: 0 6px 22px rgba(45,106,79,.28);
    transition: transform .2s, box-shadow .2s;
  }
  .btn:hover{ transform: translateY(-2px); box-shadow: 0 10px 32px rgba(45,106,79,.38); }

  @media (max-width: 980px){
    .grid{ grid-template-columns: 1fr; }
    .form-row{ grid-template-columns: 1fr; }
  }
</style>

<section class="hero">
  <div class="wrap">
    <h1 class="h1">Contact</h1>
    <p class="lead">Une question, un besoin, une demande boutique ? Écrivez-nous, on répond vite.</p>
  </div>
</section>

<section class="main">
  <div class="wrap">
    <div class="grid">

      <div class="card">
        <h2>Nous trouver</h2>
        <p class="muted">
          Passez en boutique ou envoyez-nous un message. Click &amp; Collect simple et rapide.
        </p>

        <div class="meta">
          <div class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 6-9 13-9 13S3 16 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <span>Adresse</span>
              <small>
                {% for line in store.address_lines %}{{ line }}{% if not loop.last %} • {% endif %}{% endfor %}
              </small>
            </div>
          </div>
          <div class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.8 19.8 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.8 19.8 0 013.11 4.18 2 2 0 015.09 2h3a2 2 0 012 1.72c.12.81.3 1.6.54 2.36a2 2 0 01-.45 2.11L9.91 9.91a16 16 0 006 6l1.72-1.72a2 2 0 012.11-.45c.76.24 1.55.42 2.36.54A2 2 0 0122 16.92z"/></svg>
            <div>
              <span>Téléphone</span>
              <small>{{ store.phone }}</small>
            </div>
          </div>
          <div class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M22 6l-10 7L2 6"/></svg>
            <div>
              <span>Email</span>
              <small>{{ store.email }}</small>
            </div>
          </div>
        </div>

        <div class="map" aria-label="Carte Google Maps">
          <iframe
            src="{{ store.maps_embed_url }}"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen>
          </iframe>
        </div>
      </div>

      <div class="card">
        <h2>Envoyer un message</h2>

        {% for msg in app.flashes('success') %}
          <div class="flash">{{ msg }}</div>
        {% endfor %}

        {{ form_start(form, { attr: { novalidate: 'novalidate', 'data-contact-form': '' } }) }}

          <div class="form-row">
            <div class="field">
              {{ form_label(form.name) }}
              {{ form_widget(form.name) }}
              {% if form_errors(form.name) %}<div class="error">{{ form_errors(form.name) }}</div>{% endif %}
            </div>

            <div class="field">
              {{ form_label(form.email) }}
              {{ form_widget(form.email) }}
              {% if form_errors(form.email) %}<div class="error">{{ form_errors(form.email) }}</div>{% endif %}
            </div>
          </div>

          <div class="form-row">
            <div class="field">
              {{ form_label(form.phone) }}
              {{ form_widget(form.phone) }}
              {% if form_errors(form.phone) %}<div class="error">{{ form_errors(form.phone) }}</div>{% endif %}
            </div>

            <div class="field">
              {{ form_label(form.subject) }}
              {{ form_widget(form.subject) }}
              {% if form_errors(form.subject) %}<div class="error">{{ form_errors(form.subject) }}</div>{% endif %}
            </div>
          </div>

          <div class="field">
            {{ form_label(form.message) }}
            {{ form_widget(form.message) }}
            {% if form_errors(form.message) %}<div class="error">{{ form_errors(form.message) }}</div>{% endif %}
          </div>

          <button class="btn" type="submit" data-submit-btn>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
            Envoyer
          </button>

        {{ form_end(form) }}
      </div>

    </div>
  </div>
</section>

<script>
(() => {
  const form = document.querySelector('[data-contact-form]');
  if (!form) return;

  const btn = form.querySelector('[data-submit-btn]');
  form.addEventListener('submit', () => {
    if (!btn) return;
    btn.disabled = true;
    const old = btn.innerHTML;
    btn.dataset.old = old;
    btn.innerHTML = old.replace('Envoyer', 'Envoi...');
    setTimeout(() => {
      // si backend prend du temps, on laisse disabled; sinon redirect/flash
      // au cas où la page ne se recharge pas: on réactive après 8s
      btn.disabled = false;
      btn.innerHTML = btn.dataset.old || old;
    }, 8000);
  });
})();
</script>
{% endblock %}