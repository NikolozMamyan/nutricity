{% extends 'base.html.twig' %}

{% block title %}{{ category.metaTitle ?? (category.name ~ ' - NUTRI CITY') }}{% endblock %}
{% block meta_desc %}{{ category.metaDescription ?? category.description }}{% endblock %}

{% block page_styles %}
  <link rel="stylesheet" href="{{ asset('styles/category-show.css') }}">
{% endblock %}

{% block body %}
<section class="category-page">
  <div class="category-shell">
    <header class="category-hero">
      <nav class="category-breadcrumb" aria-label="Fil d'Ariane">
        <a href="{{ path('home') }}">Accueil</a>
        <span><i class="fas fa-chevron-right"></i></span>
        <a href="{{ path('catalogue') }}">Produits</a>
        <span><i class="fas fa-chevron-right"></i></span>
        <span>{{ category.name }}</span>
      </nav>

      <div class="category-head">
        <div>
          <h1 class="category-title">{{ category.name }}</h1>
          {% if category.description %}
            <p class="category-desc">{{ category.description }}</p>
          {% endif %}
        </div>

        <a class="category-cta" href="{{ path('catalogue', { category: category.id }) }}">
          <i class="fas fa-sliders"></i>
          Voir dans le catalogue
        </a>
      </div>

      <div class="category-meta" style="margin-top:1rem;">
        <span class="category-pill"><i class="fas fa-box-open"></i> {{ total }} produit{{ total > 1 ? 's' : '' }}</span>
        <span class="category-pill"><i class="fas fa-basket-shopping"></i> Ajout rapide disponible</span>
      </div>
    </header>

    <section class="category-content">
      <div class="category-toolbar">
        <div class="category-count">{{ total }} resultat{{ total > 1 ? 's' : '' }}</div>
      </div>

      {% if products is empty %}
        <div class="category-empty">
          <h2 style="color:var(--green-900); margin-bottom:0.4rem;">Aucun produit pour le moment</h2>
          <p style="color:var(--text-muted); margin-bottom:1rem;">Cette categorie sera bientot enrichie.</p>
          <a class="category-cta" href="{{ path('catalogue') }}" style="background:linear-gradient(135deg, var(--green-800), var(--green-500)); border:none;">
            <i class="fas fa-arrow-left"></i>
            Retour au catalogue
          </a>
        </div>
      {% else %}
        <div class="category-grid">
          {% for product in products %}
            <article class="category-card">
              <a class="category-card-media" href="{{ path('product_show', { slug: product.slug }) }}">
                {% if product.photo %}
                  <img src="{{ asset('uploads/products/' ~ product.photo) }}" alt="{{ product.name }}" loading="lazy">
                {% else %}
                  <i class="fas fa-apple-alt" aria-hidden="true"></i>
                {% endif %}

                {% if product.isNew %}
                  <span class="category-card-badge">Nouveau</span>
                {% endif %}
              </a>

              <div class="category-card-body">
                <div class="category-card-top">
                  <a class="category-card-name" href="{{ path('product_show', { slug: product.slug }) }}">{{ product.name }}</a>
                  <div class="category-card-price">{{ product.price|number_format(2, ',', ' ') }} EUR</div>
                </div>

                <div class="category-card-actions">
                  <a class="category-btn-detail" href="{{ path('product_show', { slug: product.slug }) }}">
                    <i class="fas fa-eye"></i>
                    Detail
                  </a>

                  {% if product.stock > 0 %}
                    <form action="{{ path('cart_add', { id: product.id }) }}" method="post" style="flex:1.2;">
                      <input type="hidden" name="quantity" value="1">
                      <button class="category-btn-add" type="submit" style="width:100%;">
                        <i class="fas fa-cart-plus"></i>
                        Ajouter
                      </button>
                    </form>
                  {% else %}
                    <span class="category-btn-detail" style="flex:1.2; background:rgba(239,68,68,0.08); color:#b91c1c; border-color:rgba(239,68,68,0.15);">
                      <i class="fas fa-ban"></i>
                      Rupture
                    </span>
                  {% endif %}
                </div>
              </div>
            </article>
          {% endfor %}
        </div>

        {% if totalPages > 1 %}
          <nav class="category-pagination" aria-label="Pagination categorie">
            <a href="{{ path('category_show', { slug: category.slug, page: page - 1 }) }}" class="category-page-btn {{ page <= 1 ? 'is-disabled' : '' }}">
              <i class="fas fa-chevron-left"></i>
            </a>

            {% for p in 1..totalPages %}
              {% if p == 1 or p == totalPages or (p >= page - 2 and p <= page + 2) %}
                <a href="{{ path('category_show', { slug: category.slug, page: p }) }}" class="category-page-btn {{ p == page ? 'is-active' : '' }}">{{ p }}</a>
              {% elseif p == page - 3 or p == page + 3 %}
                <span class="category-page-btn is-disabled">...</span>
              {% endif %}
            {% endfor %}

            <a href="{{ path('category_show', { slug: category.slug, page: page + 1 }) }}" class="category-page-btn {{ page >= totalPages ? 'is-disabled' : '' }}">
              <i class="fas fa-chevron-right"></i>
            </a>
          </nav>
        {% endif %}
      {% endif %}
    </section>
  </div>
</section>
{% endblock %}
