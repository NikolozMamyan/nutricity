<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 220;
  padding: 12px 18px 0;
}

.site-header-shell {
  position: relative;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 16px;
  min-height: 72px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 14px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(16px);
  box-shadow: 0 16px 36px rgba(15, 23, 42, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.56);
}

.site-nav-left,
.site-nav-right {
  display: flex;
  align-items: center;
  gap: 6px;
}

.site-nav-right {
  justify-content: flex-end;
}

.site-logo {
  justify-self: center;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: var(--green-900);
}

.site-logo-mark {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--green-300), var(--green-500));
  color: #fff;
  box-shadow: 0 10px 20px rgba(82, 183, 136, 0.2);
}

.site-logo-copy {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.site-logo-title {
  font-size: 1.05rem;
  font-weight: 900;
}

.site-logo-sub {
  font-size: 0.62rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.nav-link,
.nav-trigger,
.nav-icon-btn {
  min-height: 42px;
  border-radius: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 0 14px;
  color: var(--green-900);
  font-size: 0.9rem;
  font-weight: 800;
  border: 1px solid transparent;
  transition: background var(--transition), color var(--transition), border-color var(--transition);
}

.nav-link:hover,
.nav-trigger:hover,
.nav-icon-btn:hover,
.nav-trigger.is-open {
  background: rgba(116, 198, 157, 0.1);
  border-color: rgba(82, 183, 136, 0.14);
  color: var(--green-800);
}

.nav-link.is-active {
  background: rgba(45, 106, 79, 0.07);
  border-color: rgba(45, 106, 79, 0.1);
}

.nav-trigger {
  background: none;
  cursor: pointer;
}

.nav-caret {
  font-size: 0.72rem;
  transition: transform var(--transition);
}

.nav-trigger.is-open .nav-caret {
  transform: rotate(180deg);
}

.nav-icon-btn {
  position: relative;
  width: 42px;
  padding: 0;
}

.header-cart-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 20px;
  height: 20px;
  padding: 0 5px;
  display: none;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: #ef4444;
  color: #fff;
  font-size: 0.66rem;
  font-weight: 800;
  border: 2px solid #fff;
}

.mega-menu {
  position: absolute;
  top: calc(100% + 10px);
  left: 18px;
  right: 18px;
  display: none;
  grid-template-columns: 280px minmax(0, 1fr);
  max-width: 1440px;
  margin: 0 auto;
  border-radius: 24px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.97);
  border: 1px solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 34px 70px rgba(15, 23, 42, 0.16);
}

.mega-menu.is-open {
  display: grid;
}

.mega-menu-side {
  padding: 18px;
  background:
    radial-gradient(circle at top left, rgba(116, 198, 157, 0.12), transparent 30%),
    linear-gradient(180deg, rgba(216, 243, 220, 0.36), rgba(255, 255, 255, 0.98));
  border-right: 1px solid rgba(15, 23, 42, 0.06);
}

.mega-side-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 14px;
}

.mega-eyebrow {
  font-size: 0.7rem;
  font-weight: 900;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--green-800);
}

.mega-side-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 12px;
  color: var(--green-800);
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(15, 23, 42, 0.06);
}

.mega-category-list {
  display: grid;
  gap: 8px;
}

.mega-category-link {
  display: grid;
  grid-template-columns: 38px 1fr 16px;
  align-items: center;
  gap: 10px;
  min-height: 52px;
  padding: 0 12px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid rgba(15, 23, 42, 0.06);
  color: var(--green-900);
  transition: background var(--transition), border-color var(--transition), transform var(--transition);
}

.mega-category-link:hover,
.mega-category-link.is-active {
  background: #fff;
  border-color: rgba(45, 106, 79, 0.14);
  transform: translateX(3px);
}

.mega-category-icon {
  width: 38px;
  height: 38px;
  border-radius: 13px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(116, 198, 157, 0.14);
  color: var(--green-800);
}

.mega-category-name {
  font-size: 0.9rem;
  font-weight: 800;
}

.mega-category-link i:last-child {
  font-size: 0.72rem;
  color: var(--green-500);
}

.mega-menu-main {
  padding: 18px;
  display: grid;
  gap: 14px;
}

.mega-preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.mega-preview-title {
  font-size: 1.18rem;
  font-weight: 900;
  color: var(--green-900);
}

.mega-preview-link {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  color: var(--green-800);
  font-size: 0.84rem;
  font-weight: 800;
}

.mega-subcats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.mega-subcat-card {
  position: relative;
  min-height: 132px;
  padding: 12px;
  border-radius: 18px;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(15, 23, 42, 0.3)),
    var(--green-100);
  color: #fff;
}

.mega-subcat-card img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.mega-subcat-card::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(27, 67, 50, 0.08), rgba(27, 67, 50, 0.72));
}

.mega-subcat-body {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.mega-subcat-icon {
  width: 34px;
  height: 34px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.18);
}

.mega-subcat-name {
  font-size: 0.9rem;
  font-weight: 900;
  line-height: 1.2;
  max-width: 14ch;
}

.mega-products {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.mega-product-card {
  display: grid;
  grid-template-columns: 56px 1fr auto;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 16px;
  background: rgba(248, 250, 252, 0.86);
  border: 1px solid rgba(15, 23, 42, 0.05);
  color: var(--green-900);
  transition: background var(--transition), border-color var(--transition), transform var(--transition);
}

.mega-product-card:hover {
  background: #fff;
  border-color: rgba(45, 106, 79, 0.12);
  transform: translateY(-2px);
}

.mega-product-image {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: var(--green-100);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mega-product-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.mega-product-image i {
  color: var(--green-800);
  opacity: 0.24;
}

.mega-product-name {
  font-size: 0.84rem;
  font-weight: 800;
  line-height: 1.25;
}

.mega-product-price {
  font-size: 0.8rem;
  font-weight: 900;
  color: var(--green-800);
  white-space: nowrap;
}

.mega-loading {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text-muted);
  font-size: 0.86rem;
  font-weight: 700;
}

.mobile-nav {
  display: none;
}

.mobile-nav-bar {
  position: sticky;
  top: 0;
  z-index: 230;
  display: flex;
  align-items: center;
  gap: 10px;
  min-height: 68px;
  padding: 10px 12px;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(15, 23, 42, 0.06);
}

.mobile-menu-btn,
.mobile-cart-btn {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--green-900);
  background: #fff;
}

.mobile-cart-btn {
  position: relative;
  margin-left: auto;
}

.mobile-nav-brand {
  min-width: 0;
  display: grid;
  grid-template-columns: 38px 1fr;
  align-items: center;
  gap: 10px;
  color: var(--green-900);
}

.mobile-nav-mark {
  width: 38px;
  height: 38px;
  border-radius: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--green-300), var(--green-500));
  color: #fff;
}

.mobile-nav-title {
  font-size: 0.94rem;
  font-weight: 900;
}

.mobile-nav-sub {
  font-size: 0.58rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.mobile-menu-overlay {
  position: fixed;
  inset: 0;
  z-index: 225;
  display: none;
  background: rgba(15, 23, 42, 0.42);
  backdrop-filter: blur(4px);
}

.mobile-menu-overlay.is-active {
  display: block;
}

.mobile-menu-drawer {
  position: fixed;
  inset: 0 auto 0 0;
  z-index: 230;
  width: min(88vw, 360px);
  padding: 10px;
  transform: translateX(-104%);
  transition: transform var(--transition), box-shadow var(--transition);
}

.mobile-menu-drawer.is-open {
  transform: translateX(0);
  box-shadow: 22px 0 64px rgba(15, 23, 42, 0.24);
}

.mobile-menu-shell {
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 16px 14px;
  border-radius: 24px;
  background:
    radial-gradient(circle at top left, rgba(116, 198, 157, 0.16), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(254, 250, 224, 0.98));
}

.mobile-menu-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.mobile-menu-close {
  width: 38px;
  height: 38px;
  border-radius: 12px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  background: #fff;
  color: var(--green-900);
}

.mobile-menu-links,
.mobile-category-list {
  display: grid;
  gap: 8px;
}

.mobile-menu-link,
.mobile-category-pill {
  min-height: 48px;
  padding: 0 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  border-radius: 16px;
  background: #fff;
  border: 1px solid rgba(15, 23, 42, 0.06);
  color: var(--green-900);
  font-size: 0.9rem;
  font-weight: 800;
}

.mobile-menu-label {
  font-size: 0.7rem;
  font-weight: 900;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--green-800);
}

.mobile-submenu {
  display: none;
  gap: 8px;
  padding: 6px 0 2px 10px;
}

.mobile-submenu.is-open {
  display: grid;
}

.mobile-submenu-item {
  min-height: 52px;
  display: grid;
  grid-template-columns: 42px 1fr auto;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  border-radius: 16px;
  background: rgba(255,255,255,0.74);
  border: 1px solid rgba(15,23,42,0.05);
  color: var(--green-900);
}

.mobile-submenu-thumb {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  overflow: hidden;
  background: var(--green-100);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mobile-submenu-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.mobile-submenu-thumb i {
  color: var(--green-800);
  opacity: 0.26;
}

.mobile-submenu-name {
  font-size: 0.82rem;
  font-weight: 800;
  line-height: 1.2;
}

.mobile-submenu-price {
  font-size: 0.76rem;
  font-weight: 900;
  color: var(--green-800);
  white-space: nowrap;
}

.cart-shake {
  animation: cartShake 0.45s ease;
}

@keyframes cartShake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-2px) rotate(-4deg); }
  50% { transform: translateX(2px) rotate(4deg); }
  75% { transform: translateX(-1px) rotate(-2deg); }
}

@media (max-width: 1180px) {
  .mega-subcats,
  .mega-products {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 860px) {
  .site-header {
    display: none;
  }

  .mobile-nav {
    display: block;
  }
}
</style>

<header class="site-header" data-layout-target="header">
  <div class="site-header-shell">
    <div class="site-nav-left">
      <a class="nav-link {% if app.request.attributes.get('_route') == 'home' %}is-active{% endif %}" href="{{ path('home') }}">
        <i class="fas fa-house" aria-hidden="true"></i>
      </a>

      <button
        type="button"
        class="nav-trigger"
        data-action="click->layout#toggleMegaMenu"
        data-layout-target="megaTrigger"
        aria-expanded="false"
        aria-controls="siteMegaMenu"
      >
        <i class="fas fa-grid-2" aria-hidden="true"></i>
        Produits
        <i class="fas fa-chevron-down nav-caret" aria-hidden="true"></i>
      </button>

      <a class="nav-link {% if app.request.attributes.get('_route') == 'about' %}is-active{% endif %}" href="{{ path('about') }}">
        <i class="fas fa-circle-info" aria-hidden="true"></i>
      </a>

      <a class="nav-link {% if app.request.attributes.get('_route') == 'contact' %}is-active{% endif %}" href="{{ path('contact') }}">
        <i class="fas fa-envelope" aria-hidden="true"></i>
      </a>
    </div>

    <a class="site-logo" href="{{ path('home') }}" aria-label="NUTRI CITY - Accueil">
      <span class="site-logo-mark"><i class="fas fa-seedling" aria-hidden="true"></i></span>
      <span class="site-logo-copy">
        <span class="site-logo-title">NUTRI CITY</span>
        <span class="site-logo-sub">Simple et rapide</span>
      </span>
    </a>

    <div class="site-nav-right">
      <a class="nav-icon-btn" href="{{ path('catalogue') }}" aria-label="Catalogue">
        <i class="fas fa-search" aria-hidden="true"></i>
      </a>

      <a
        href="{{ path('click_collect') }}"
        class="nav-icon-btn {% if app.request.attributes.get('_route') == 'click_collect' %}is-active{% endif %}"
        data-controller="cart-badge"
        data-cart-badge-url-value="{{ path('cart_data')|default('/panier/donnees') }}"
        aria-label="Panier"
      >
        <i class="fas fa-shopping-basket" aria-hidden="true"></i>
        <span class="header-cart-badge" data-cart-badge-target="badge"></span>
      </a>
    </div>
  </div>

  <div
    id="siteMegaMenu"
    class="mega-menu"
    data-layout-target="megaMenu"
    data-layout-preview-url-template-value="{{ path('category_preview', { slug: '__slug__' }) }}"
  >
    <div class="mega-menu-side">
      <div class="mega-side-top">
        <div class="mega-eyebrow">Rayons</div>
        <a class="mega-side-link" href="{{ path('catalogue') }}" aria-label="Voir tout le catalogue">
          <i class="fas fa-arrow-right" aria-hidden="true"></i>
        </a>
      </div>

      <div class="mega-category-list">
        {% for category in nav_categories %}
          <a
            class="mega-category-link {{ loop.first ? 'is-active' : '' }}"
            href="{{ path('category_show', { slug: category.slug }) }}"
            data-action="mouseenter->layout#previewCategory focus->layout#previewCategory"
            data-slug="{{ category.slug }}"
          >
            <span class="mega-category-icon"><i class="fas fa-leaf" aria-hidden="true"></i></span>
            <span class="mega-category-name">{{ category.name }}</span>
            <i class="fas fa-chevron-right" aria-hidden="true"></i>
          </a>
        {% else %}
          <a class="mega-category-link" href="{{ path('catalogue') }}">
            <span class="mega-category-icon"><i class="fas fa-store" aria-hidden="true"></i></span>
            <span class="mega-category-name">Catalogue</span>
            <i class="fas fa-chevron-right" aria-hidden="true"></i>
          </a>
        {% endfor %}
      </div>
    </div>

    <div class="mega-menu-main">
      <div class="mega-preview-head">
        <div class="mega-preview-title" data-layout-target="previewTitle">
          {{ nav_categories|first ? nav_categories|first.name : 'Produits' }}
        </div>

        <a class="mega-preview-link" href="{{ nav_categories|first ? path('category_show', { slug: nav_categories|first.slug }) : path('catalogue') }}" data-layout-target="previewLink">
          Voir tout
          <i class="fas fa-arrow-right" aria-hidden="true"></i>
        </a>
      </div>

      <div class="mega-subcats" data-layout-target="previewSubcats">
        {% for product in nav_featured_products|slice(0, 3) %}
          <a class="mega-subcat-card" href="{{ path('product_show', { slug: product.slug }) }}">
            {% if product.photo %}
              <img src="{{ asset('uploads/products/' ~ product.photo) }}" alt="{{ product.name }}" loading="lazy">
            {% endif %}
            <div class="mega-subcat-body">
              <span class="mega-subcat-icon"><i class="fas fa-star" aria-hidden="true"></i></span>
              <span class="mega-subcat-name">{{ product.name }}</span>
            </div>
          </a>
        {% endfor %}
      </div>

      <div class="mega-products" data-layout-target="previewProducts">
        {% for product in nav_featured_products|slice(0, 6) %}
          <a class="mega-product-card" href="{{ path('product_show', { slug: product.slug }) }}">
            <div class="mega-product-image">
              {% if product.photo %}
                <img src="{{ asset('uploads/products/' ~ product.photo) }}" alt="{{ product.name }}" loading="lazy">
              {% else %}
                <i class="fas fa-apple-alt" aria-hidden="true"></i>
              {% endif %}
            </div>
            <div class="mega-product-name">{{ product.name }}</div>
            <div class="mega-product-price">{{ product.price|number_format(2, ',', ' ') }} EUR</div>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</header>

<div class="mobile-nav">
  <div class="mobile-nav-bar">
    <button
      type="button"
      class="mobile-menu-btn"
      aria-label="Ouvrir le menu"
      data-action="click->layout#openMobileMenu"
      data-layout-target="toggleBtn"
    >
      <i class="fas fa-bars" data-layout-target="toggleIcon" aria-hidden="true"></i>
    </button>

    <a class="mobile-nav-brand" href="{{ path('home') }}" aria-label="NUTRI CITY - Accueil">
      <span class="mobile-nav-mark"><i class="fas fa-seedling" aria-hidden="true"></i></span>
      <span>
        <span class="mobile-nav-title">NUTRI CITY</span>
        <span class="mobile-nav-sub">Click &amp; Collect</span>
      </span>
    </a>

    <a
      href="{{ path('click_collect') }}"
      class="mobile-cart-btn"
      data-controller="cart-badge"
      data-cart-badge-url-value="{{ path('cart_data')|default('/panier/donnees') }}"
      data-layout-target="mobileCartIcon"
      aria-label="Panier"
    >
      <i class="fas fa-shopping-basket" aria-hidden="true"></i>
      <span class="header-cart-badge" data-cart-badge-target="badge"></span>
    </a>
  </div>

  <div class="mobile-menu-overlay" data-layout-target="overlay" data-action="click->layout#closeMobileMenu"></div>

  <aside class="mobile-menu-drawer" data-layout-target="sidebar">
    <div class="mobile-menu-shell">
      <div class="mobile-menu-head">
        <a class="site-logo" href="{{ path('home') }}" aria-label="NUTRI CITY - Accueil">
          <span class="site-logo-mark"><i class="fas fa-seedling" aria-hidden="true"></i></span>
          <span class="site-logo-copy">
            <span class="site-logo-title">NUTRI CITY</span>
            <span class="site-logo-sub">Fluide et intuitif</span>
          </span>
        </a>

        <button type="button" class="mobile-menu-close" data-action="click->layout#closeMobileMenu" aria-label="Fermer le menu">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>

      <div class="mobile-menu-links">
        <a class="mobile-menu-link" href="{{ path('home') }}"><span><i class="fas fa-house"></i> Accueil</span><i class="fas fa-arrow-right"></i></a>
        <a class="mobile-menu-link" href="{{ path('catalogue') }}"><span><i class="fas fa-store"></i> Catalogue</span><i class="fas fa-arrow-right"></i></a>
        <a class="mobile-menu-link" href="{{ path('click_collect') }}"><span><i class="fas fa-shopping-basket"></i> Panier</span><i class="fas fa-arrow-right"></i></a>
      </div>

      <div class="mobile-menu-label">Categories</div>
      <div class="mobile-category-list">
        {% for category in nav_categories %}
          <div>
            <a
              class="mobile-category-pill"
              href="{{ path('category_show', { slug: category.slug }) }}"
              data-action="click->layout#toggleMobileSubmenu"
              data-slug="{{ category.slug }}"
            >
              <span><i class="fas fa-leaf"></i> {{ category.name }}</span>
              <i class="fas fa-chevron-down" aria-hidden="true"></i>
            </a>
            <div class="mobile-submenu" data-layout-mobile-submenu="{{ category.slug }}"></div>
          </div>
        {% endfor %}
      </div>
    </div>
  </aside>
</div>
