{% extends 'base.html.twig' %}
{% block title %}À propos – {{ store.name }}{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap');
  :root{
    --pg-cream:#FEFAE0; --pg-green:#2D6A4F; --pg-green-l:#52B788; --pg-green-p:#D8F3DC;
    --pg-dark:#1B4332; --pg-muted:#6b7280; --pg-border:rgba(0,0,0,.07);
    --pg-shadow:0 4px 28px rgba(0,0,0,.07); --pg-shadow-l:0 12px 48px rgba(0,0,0,.12);
    --wrap:1120px; --gutter:clamp(16px, 3vw, 28px);
  }

  .wrap{ width:min(var(--wrap), calc(100% - (var(--gutter) * 2))); margin-inline:auto; }
  :where(a,button,input):focus-visible{ outline:3px solid rgba(82,183,136,.45); outline-offset:3px; border-radius:14px; }

  .hero{
    background:
      radial-gradient(ellipse at 20% 80%, rgba(82,183,136,.18) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(116,198,157,.1) 0%, transparent 45%),
      linear-gradient(145deg, var(--pg-dark) 0%, var(--pg-green) 100%);
    padding: 3rem 0 2.2rem;
    position:relative; overflow:hidden;
  }
  .hero::after{ content:''; position:absolute; inset:0;
    background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px; pointer-events:none;
  }
  .eyebrow{
    font-size:.72rem; font-weight:800; letter-spacing:.14em; text-transform:uppercase;
    color: rgba(255,255,255,.75); margin-bottom:.65rem; display:flex; align-items:center; gap:8px;
  }
  .eyebrow::before{ content:''; width:26px; height:2px; background:var(--pg-green-l); border-radius:2px; }
  .h1{
    font-family:'Playfair Display',serif;
    font-size: clamp(2rem, 4.2vw, 3.2rem);
    font-weight: 900; color: #fff; line-height:1.05; margin:0 0 .8rem;
  }
  .lead{ max-width:70ch; color: rgba(255,255,255,.75); line-height:1.7; font-size:1rem; margin:0; }

  .main{ padding: 3.2rem 0 4.4rem; }
  .grid{ display:grid; grid-template-columns: 1.05fr .95fr; gap: clamp(18px, 3vw, 40px); align-items:start; }
  .card{
    background:#fff; border:1.5px solid rgba(45,106,79,.12); border-radius:22px;
    box-shadow: var(--pg-shadow); padding: 1.6rem; position:relative; overflow:hidden;
  }
  .card::before{ content:''; position:absolute; top:0; left:0; right:0; height:3px;
    background: linear-gradient(90deg, var(--pg-green), var(--pg-green-l));
  }
  .card h2{
    font-family:'Playfair Display',serif; font-weight:900; color:var(--pg-dark);
    font-size:1.5rem; margin: .2rem 0 1rem;
  }
  .p{ color:var(--pg-muted); line-height:1.85; margin: .8rem 0; font-size:.95rem; }
  .p strong{ color:var(--pg-dark); }
  .pillrow{ display:flex; flex-wrap:wrap; gap:10px; margin-top:1.1rem; }
  .pill{
    display:inline-flex; align-items:center; gap:8px;
    background: var(--pg-green-p); color: var(--pg-green);
    border: 1.5px solid rgba(45,106,79,.15);
    border-radius: 999px; padding: 8px 12px;
    font-size:.82rem; font-weight:700;
  }
  .pill svg{ width:14px; height:14px; }

  .info{
    display:grid; gap:12px;
  }
  .infobox{
    background: #fff; border:1.5px solid var(--pg-border); border-radius:18px;
    padding: 1.2rem; box-shadow: 0 1px 10px rgba(0,0,0,.04);
  }
  .infotitle{ font-weight:800; color:var(--pg-dark); font-size:.95rem; margin:0 0 .35rem; }
  .infotext{ color:var(--pg-muted); line-height:1.7; font-size:.9rem; margin:0; }
  .link{
    display:inline-flex; align-items:center; gap:8px; margin-top:10px;
    color: var(--pg-green); text-decoration:none; font-weight:800; font-size:.9rem;
  }
  .link:hover{ text-decoration: underline; }

  @media (max-width: 980px){
    .grid{ grid-template-columns: 1fr; }
  }
</style>

<section class="hero">
  <div class="wrap">
    <div class="eyebrow">Notre magasin</div>
    <h1 class="h1">{{ store.name }}</h1>
    <p class="lead">
      Une sélection pointue, des produits fiables, et un retrait Click &amp; Collect simple et rapide.
      Passez nous voir en boutique — on est là pour vous conseiller.
    </p>
  </div>
</section>

<section class="main">
  <div class="wrap">
    <div class="grid">
      <div class="card">
        <h2>Pourquoi {{ store.name }} ?</h2>
        <p class="p">
          Notre mission : proposer des produits de qualité, clairs, et utiles au quotidien.
          On privilégie des références sérieuses, des marques reconnues, et une expérience d’achat fluide.
        </p>
        <p class="p">
          <strong>Vous commandez en ligne</strong>, et vous récupérez en magasin — sans stress.
          Besoin d’un conseil ? On vous oriente rapidement selon vos objectifs.
        </p>

        <div class="pillrow" aria-label="Points forts">
          <span class="pill">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Sélection qualité
          </span>
          <span class="pill">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            Retrait rapide
          </span>
          <span class="pill">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            Boutique Strasbourg
          </span>
        </div>
      </div>

      <div class="info">
        <div class="infobox">
          <div class="infotitle">Adresse</div>
          <p class="infotext">
            {% for line in store.address_lines %}{{ line }}{% if not loop.last %}<br>{% endif %}{% endfor %}
          </p>
        </div>

        <div class="infobox">
          <div class="infotitle">Contact</div>
          <p class="infotext">
            Téléphone : {{ store.phone }}<br>
            Email : {{ store.email }}
          </p>
          <a class="link" href="{{ path('contact') }}">
            Nous écrire
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="infobox">
          <div class="infotitle">Click &amp; Collect</div>
          <p class="infotext">
            Commandez en ligne et récupérez en magasin. Simple, rapide, efficace.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}