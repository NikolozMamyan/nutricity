{% extends 'admin/layout.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block body %}
  <div class="hstack" style="justify-content:space-between; margin-bottom:12px;">
    <h1>{{ title }}</h1>
    <a class="btn" href="{{ path('admin_users_index') }}">Retour</a>
  </div>

  <div class="card">
    {{ form_start(form) }}
      <div class="form-row">
        <div>{{ form_row(form.email) }}</div>
        <div>{{ form_row(form.plainPassword) }}</div>
        <div>{{ form_row(form.firstName) }}</div>
        <div>{{ form_row(form.lastName) }}</div>

        <div class="full">
          <div class="muted" style="margin:8px 0;">Rôles</div>
          {{ form_widget(form.roles) }}
        </div>

        <div class="full">
          {{ form_row(form.needsPasswordSetup) }}
        </div>
      </div>

      <div class="hstack" style="margin-top:12px;">
        <button class="btn btn-primary">Enregistrer</button>
        <a class="btn" href="{{ path('admin_users_index') }}">Annuler</a>
      </div>
    {{ form_end(form) }}
  </div>

  {# reset password #}
  {% if app.request.attributes.get('_route') == 'admin_users_edit' %}
    <div style="height:12px"></div>
    <div class="card">
      <div class="hstack" style="justify-content:space-between;">
        <div>
          <div style="font-weight:900;">Réinitialisation mot de passe</div>
          <div class="muted">Génère un mot de passe temporaire et active needsPasswordSetup.</div>
        </div>
        <form method="post" action="{{ path('admin_users_reset_password', {id: app.request.get('id')}) }}">
          <input type="hidden" name="_token" value="{{ csrf_token('reset_pwd_' ~ app.request.get('id')) }}">
          <button class="btn btn-soft" data-confirm="Réinitialiser le mot de passe ?">Reset password</button>
        </form>
      </div>
    </div>
  {% endif %}
{% endblock %}