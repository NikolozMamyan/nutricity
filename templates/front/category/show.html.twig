{% extends 'base.html.twig' %}

{% block title %}{{ category.metaTitle ?? (category.name ~ ' - NUTRI CITY') }}{% endblock %}
{% block meta_desc %}{{ category.metaDescription ?? category.description }}{% endblock %}

{% block page_styles %}
  <link rel="stylesheet" href="{{ asset('styles/category-show.css') }}">
{% endblock %}

{% block body %}
<section
  class="category-page"
  data-controller="category-page"
>
  <div class="category-shell">
    <div class="toast-container" aria-live="polite" data-category-page-target="toastContainer"></div>

    <header class="category-hero">
      <nav class="category-breadcrumb" aria-label="Fil d'Ariane">
        <a href="{{ path('home') }}">Accueil</a>
        <span><i class="fas fa-chevron-right"></i></span>
        <a href="{{ path('catalogue') }}">Produits</a>
        <span><i class="fas fa-chevron-right"></i></span>
        <span>{{ category.name }}</span>
      </nav>

      <div class="category-head">
        <div class="category-head-copy">
          <span class="category-kicker">
            <i class="fas fa-leaf"></i>
            Selection {{ category.name }}
          </span>
          <h1 class="category-title">{{ category.name }}</h1>
          {% if category.description %}
            <p class="category-desc">{{ category.description }}</p>
          {% endif %}
        </div>

        <div class="category-head-actions">
          <a class="category-cta is-secondary" href="{{ path('catalogue', { category: category.id }) }}">
            <i class="fas fa-grid-2"></i>
            <span>Catalogue</span>
          </a>

          <a class="category-cta" href="{{ path('click_collect') }}">
            <i class="fas fa-basket-shopping"></i>
            <span>Panier</span>
          </a>
        </div>
      </div>

      <div class="category-meta">
        <span class="category-pill"><i class="fas fa-box-open"></i> {{ total }} produit{{ total > 1 ? 's' : '' }}</span>
        <span class="category-pill"><i class="fas fa-bolt"></i> Ajout express</span>
        <span class="category-pill"><i class="fas fa-mobile-screen"></i> Mobile first</span>
      </div>
    </header>

    <section class="category-content">
      <div class="category-toolbar">
        <div class="category-count">
          <span class="category-count-strong">{{ total }}</span>
          resultat{{ total > 1 ? 's' : '' }}
        </div>

        <div class="category-toolbar-links">
          <a href="{{ path('catalogue', { category: category.id }) }}">
            <i class="fas fa-sliders"></i>
            <span>Filtres</span>
          </a>
          <a href="{{ path('click_collect') }}">
            <i class="fas fa-bag-shopping"></i>
            <span>Commander</span>
          </a>
        </div>
      </div>

      {% if products is empty %}
        <div class="category-empty">
          <div class="category-empty-icon"><i class="fas fa-seedling"></i></div>
          <h2>Aucun produit pour le moment</h2>
          <p>Cette categorie sera bientot enrichie.</p>
          <a class="category-cta" href="{{ path('catalogue') }}">
            <i class="fas fa-arrow-left"></i>
            <span>Retour au catalogue</span>
          </a>
        </div>
      {% else %}
        <div class="category-grid">
          {% for product in products %}
            <article class="category-card">
              <a class="category-card-media" href="{{ path('product_show', { slug: product.slug }) }}" aria-label="{{ product.name }}">
                {% if product.photo %}
                  <img src="{{ asset('uploads/products/' ~ product.photo) }}" alt="{{ product.name }}" loading="lazy">
                {% else %}
                  <i class="fas fa-apple-alt" aria-hidden="true"></i>
                {% endif %}

                {% if product.isNew %}
                  <span class="category-card-badge">Nouveau</span>
                {% endif %}

                <div class="category-card-overlay">
                  <span><i class="fas fa-eye"></i> Voir</span>
                </div>
              </a>

              <div class="category-card-body">
                <div class="category-card-meta">
                  {% if product.origin %}
                    <span><i class="fas fa-location-dot"></i> {{ product.origin }}</span>
                  {% else %}
                    <span><i class="fas fa-leaf"></i> Nutri City</span>
                  {% endif %}

                  {% if product.stock > 0 %}
                    <span class="is-stock"><i class="fas fa-circle-check"></i> En stock</span>
                  {% endif %}
                </div>

                <div class="category-card-top">
                  <a class="category-card-name" href="{{ path('product_show', { slug: product.slug }) }}">{{ product.name }}</a>
                  {% if product.shortDescription %}
                    <p class="category-card-desc">{{ product.shortDescription }}</p>
                  {% endif %}
                  <div class="category-card-price">{{ product.price|number_format(2, ',', ' ') }} <small>EUR</small></div>
                </div>

                <div class="category-card-actions">
                  {% if product.stock > 0 %}
                    <form
                      action="{{ path('cart_add', { id: product.id }) }}"
                      method="post"
                      data-action="submit->category-page#addToCart"
                      data-product-name="{{ product.name }}"
                      class="category-add-form"
                    >
                      <input type="hidden" name="quantity" value="1">
                      <button class="category-btn-add" type="submit" data-role="add-button">
                        <i class="fas fa-cart-plus"></i>
                        <span>Ajouter</span>
                      </button>
                    </form>
                  {% else %}
                    <span class="category-btn-state is-out">
                      <i class="fas fa-ban"></i>
                      <span>Rupture</span>
                    </span>
                  {% endif %}

                  <a class="category-btn-detail" href="{{ path('product_show', { slug: product.slug }) }}">
                    <i class="fas fa-eye"></i>
                    <span>Detail</span>
                  </a>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>

        {% if totalPages > 1 %}
          <nav class="category-pagination" aria-label="Pagination categorie">
            <a href="{{ path('category_show', { slug: category.slug, page: page - 1 }) }}" class="category-page-btn {{ page <= 1 ? 'is-disabled' : '' }}">
              <i class="fas fa-chevron-left"></i>
            </a>

            {% for p in 1..totalPages %}
              {% if p == 1 or p == totalPages or (p >= page - 2 and p <= page + 2) %}
                <a href="{{ path('category_show', { slug: category.slug, page: p }) }}" class="category-page-btn {{ p == page ? 'is-active' : '' }}">{{ p }}</a>
              {% elseif p == page - 3 or p == page + 3 %}
                <span class="category-page-btn is-disabled">...</span>
              {% endif %}
            {% endfor %}

            <a href="{{ path('category_show', { slug: category.slug, page: page + 1 }) }}" class="category-page-btn {{ page >= totalPages ? 'is-disabled' : '' }}">
              <i class="fas fa-chevron-right"></i>
            </a>
          </nav>
        {% endif %}
      {% endif %}
    </section>
  </div>
</section>
{% endblock %}
