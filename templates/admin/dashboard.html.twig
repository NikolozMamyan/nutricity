{% extends 'admin/layout.html.twig' %}
{% block title %}Dashboard{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap');

  .dash { font-family: 'DM Sans', sans-serif; max-width: 1200px; }

  /* ── Header ──────────────────────────────── */
  .dash-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    flex-wrap: wrap; gap: 14px; margin-bottom: 26px;
  }
  .dash-greeting { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: var(--nutri-green); margin-bottom: 4px; }
  .dash-title    { font-size: 26px; font-weight: 800; color: var(--nutri-dark); line-height: 1.2; }
  .dash-sub      { font-size: 13px; color: var(--text-muted); margin-top: 4px; }
  .dash-actions  { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

  .dbt {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 16px; border-radius: 10px;
    font-size: 13px; font-weight: 700; text-decoration: none;
    transition: all .15s; font-family: 'DM Sans', sans-serif;
  }
  .dbt-primary {
    background: var(--nutri-green); color: #fff;
    border: none; box-shadow: 0 4px 12px rgba(45,106,79,.25);
  }
  .dbt-primary:hover { background: var(--nutri-dark); transform: translateY(-1px); }
  .dbt-ghost {
    background: rgba(255,255,255,.8); color: var(--nutri-dark);
    border: 1.5px solid var(--border);
  }
  .dbt-ghost:hover { background: var(--nutri-green-pale); border-color: var(--nutri-green-light); }

  /* ── KPI grid ────────────────────────────── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 12px;
  }
  .kpi-card {
    background: rgba(255,255,255,.82); border: 1.5px solid var(--border);
    border-radius: 16px; padding: 18px 18px 16px;
    box-shadow: var(--shadow-sm); transition: box-shadow .2s, transform .2s;
    position: relative; overflow: hidden;
  }
  .kpi-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .kpi-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    border-radius: 16px 16px 0 0;
  }
  .kpi-card.green::before  { background: linear-gradient(90deg, var(--nutri-green), var(--nutri-green-light)); }
  .kpi-card.amber::before  { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
  .kpi-card.blue::before   { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
  .kpi-card.purple::before { background: linear-gradient(90deg, #6366f1, #818cf8); }
  .kpi-card.orange::before { background: linear-gradient(90deg, #f97316, #fb923c); }

  .kpi-icon {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px; flex-shrink: 0;
  }
  .kpi-card.green  .kpi-icon { background: rgba(45,106,79,.1);  color: var(--nutri-green); }
  .kpi-card.amber  .kpi-icon { background: rgba(245,158,11,.1); color: #d97706; }
  .kpi-card.blue   .kpi-icon { background: rgba(59,130,246,.1); color: #2563eb; }
  .kpi-card.purple .kpi-icon { background: rgba(99,102,241,.1); color: #4f46e5; }
  .kpi-card.orange .kpi-icon { background: rgba(249,115,22,.1); color: #ea580c; }

  .kpi-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--text-muted); margin-bottom: 6px; }
  .kpi-val   { font-size: 32px; font-weight: 800; color: var(--nutri-dark); letter-spacing: -.02em; line-height: 1; }
  .kpi-sub   { font-size: 12px; color: var(--text-muted); margin-top: 6px; }

  /* ── Abandoned carts wide card ───────────── */
  .kpi-wide {
    grid-column: 1 / -1;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    background: rgba(249,115,22,.05); border-color: rgba(249,115,22,.2);
    padding: 16px 20px;
  }
  .kpi-wide .kpi-left { display: flex; align-items: center; gap: 14px; }
  .kpi-wide .kpi-val  { font-size: 26px; }
  .kpi-wide-link {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; border-radius: 9px;
    border: 1.5px solid rgba(249,115,22,.25); background: rgba(249,115,22,.08);
    color: #ea580c; font-size: 12px; font-weight: 700; text-decoration: none;
    transition: all .15s;
  }
  .kpi-wide-link:hover { background: #f97316; color: #fff; border-color: #f97316; }

  /* ── Recent orders ───────────────────────── */
  .section-card {
    background: rgba(255,255,255,.82); border: 1.5px solid var(--border);
    border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-sm);
    margin-top: 12px;
  }
  .section-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px; border-bottom: 1px solid rgba(0,0,0,.05);
  }
  .section-title {
    font-size: 14px; font-weight: 700; color: var(--nutri-dark);
    display: flex; align-items: center; gap: 8px;
  }
  .section-title-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--nutri-green);
    box-shadow: 0 0 0 3px rgba(45,106,79,.15);
  }
  .see-all {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 12px; font-weight: 600; color: var(--nutri-green);
    text-decoration: none; transition: color .15s;
  }
  .see-all:hover { color: var(--nutri-dark); }

  .orders-table { width: 100%; border-collapse: collapse; }
  .orders-table thead th {
    padding: 10px 14px;
    background: var(--nutri-green-pale);
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .06em; color: var(--nutri-green); text-align: left;
  }
  .orders-table tbody td {
    padding: 12px 14px; border-bottom: 1px solid rgba(0,0,0,.04);
    font-size: 13px; vertical-align: middle;
  }
  .orders-table tbody tr:last-child td { border-bottom: none; }
  .orders-table tbody tr:hover td { background: rgba(216,243,220,.18); }
  .orders-table tbody tr { transition: background .1s; }

  .onum { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 600; color: var(--nutri-green); }
  .oclient { font-weight: 600; color: var(--nutri-dark); }
  .ototal  { font-weight: 700; color: var(--nutri-dark); }
  .odate   { font-size: 12px; color: var(--text-muted); white-space: nowrap; }

  .sbadge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 600;
    border: 1.5px solid transparent; white-space: nowrap;
  }
  .sbadge-dot { width: 6px; height: 6px; border-radius: 50%; }
  .sbadge.NOUVELLE,.sbadge.new        { background:rgba(245,158,11,.1); border-color:rgba(245,158,11,.3); color:#92400e; }
  .sbadge.NOUVELLE .sbadge-dot,.sbadge.new .sbadge-dot { background:#f59e0b; }
  .sbadge.VALIDEE,.sbadge.validated   { background:rgba(16,185,129,.1); border-color:rgba(16,185,129,.3); color:#065f46; }
  .sbadge.VALIDEE .sbadge-dot,.sbadge.validated .sbadge-dot { background:#10b981; }
  .sbadge.EN_PREPARATION,.sbadge.processing { background:rgba(99,102,241,.1); border-color:rgba(99,102,241,.3); color:#3730a3; }
  .sbadge.EN_PREPARATION .sbadge-dot,.sbadge.processing .sbadge-dot { background:#6366f1; }
  .sbadge.PRETE_A_RETIRER,.sbadge.ready { background:rgba(59,130,246,.1); border-color:rgba(59,130,246,.3); color:#1e40af; }
  .sbadge.PRETE_A_RETIRER .sbadge-dot,.sbadge.ready .sbadge-dot { background:#3b82f6; }
  .sbadge.RETIREE,.sbadge.collected   { background:rgba(45,106,79,.1); border-color:rgba(45,106,79,.3); color:var(--nutri-dark); }
  .sbadge.RETIREE .sbadge-dot,.sbadge.collected .sbadge-dot { background:var(--nutri-green); }
  .sbadge.ANNULEE,.sbadge.cancelled   { background:rgba(239,68,68,.1); border-color:rgba(239,68,68,.3); color:#991b1b; }
  .sbadge.ANNULEE .sbadge-dot,.sbadge.cancelled .sbadge-dot { background:#ef4444; }

  .btn-row {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 10px; border-radius: 7px;
    border: 1.5px solid var(--border); background: #fff;
    font-size: 11px; font-weight: 600; text-decoration: none;
    color: var(--nutri-dark); transition: all .15s;
  }
  .btn-row:hover { background: var(--nutri-green-pale); border-color: var(--nutri-green-light); }

  .empty-row td { text-align: center; padding: 32px; color: var(--text-muted); font-style: italic; font-size: 13px; }
</style>



  {# ── Header ──────────────────────────────── #}
  <div class="dash-header">
    <div>
      <div class="dash-greeting">Bonjour 👋</div>
      <div class="dash-title">Dashboard</div>
      <div class="dash-sub">Vue d'ensemble — commandes, catalogue, clients.</div>
    </div>
    <div class="dash-actions">
      <a href="{{ path('admin_orders_new') }}" class="dbt dbt-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nouvelle commande
      </a>
      <a href="{{ path('admin_products_new') }}" class="dbt dbt-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Ajouter un produit
      </a>
    </div>
  </div>

  {# ── KPI cards ────────────────────────────── #}
  <div class="kpi-grid">

    <div class="kpi-card amber">
      <div class="kpi-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      </div>
      <div class="kpi-label">Nouvelles commandes</div>
      <div class="kpi-val">{{ kpis.orders_new }}</div>
      <div class="kpi-sub">En attente de validation</div>
    </div>

    <div class="kpi-card green">
      <div class="kpi-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>
      </div>
      <div class="kpi-label">Commandes aujourd'hui</div>
      <div class="kpi-val">{{ kpis.orders_today }}</div>
      <div class="kpi-sub">Reçues ce jour</div>
    </div>

    <div class="kpi-card blue">
      <div class="kpi-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </div>
      <div class="kpi-label">Produits actifs</div>
      <div class="kpi-val">{{ kpis.products_active }}</div>
      <div class="kpi-sub">Disponibles à la vente</div>
    </div>

    <div class="kpi-card purple">
      <div class="kpi-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      </div>
      <div class="kpi-label">Utilisateurs</div>
      <div class="kpi-val">{{ kpis.users_total }}</div>
      <div class="kpi-sub">Comptes enregistrés</div>
    </div>

    <div class="kpi-card orange kpi-wide">
      <div class="kpi-left">
        <div class="kpi-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.96-1.61L23 6H6"/></svg>
        </div>
        <div>
          <div class="kpi-label">Paniers abandonnés</div>
          <div class="kpi-val">{{ kpis.abandoned_carts }}</div>
          <div class="kpi-sub">Clients à relancer</div>
        </div>
      </div>
      <a href="{{ path('admin_carts_index') }}" class="kpi-wide-link">
        Voir les paniers
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>

  {# ── Recent orders ─────────────────────────── #}
  <div class="section-card">
    <div class="section-head">
      <div class="section-title">
        <span class="section-title-dot"></span>
        Dernières commandes
      </div>
      <a href="{{ path('admin_orders_index') }}" class="see-all">
        Voir toutes
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <table class="orders-table">
      <thead>
        <tr>
          <th>N° commande</th>
          <th>Client</th>
          <th>Statut</th>
          <th>Total</th>
          <th>Date</th>
          <th style="width:80px;"></th>
        </tr>
      </thead>
      <tbody>
        {% for o in latestOrders %}
          <tr>
            <td><div class="onum">{{ o.orderNumber }}</div></td>
            <td><div class="oclient">{{ o.fullName ?: '—' }}</div></td>
            <td>
              <span class="sbadge {{ o.status }}">
                <span class="sbadge-dot"></span>
                {{ o.statusLabel }}
              </span>
            </td>
            <td class="ototal">{{ o.total }} €</td>
            <td class="odate">{{ o.createdAt|date('d/m/Y H:i') }}</td>
            <td>
              <a href="{{ path('admin_orders_show', {id: o.id}) }}" class="btn-row">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                Ouvrir
              </a>
            </td>
          </tr>
        {% else %}
          <tr class="empty-row"><td colspan="6">Aucune commande pour le moment.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>


{% endblock %}
